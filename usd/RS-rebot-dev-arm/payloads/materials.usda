def Scope "Materials"
{
    def Material "material_20"
    {
        token outputs:displacement (
            displayGroup = "Outputs"
        )
        prepend token outputs:mdl:displacement.connect = </Materials/material_20/Shader.outputs:out>
        prepend token outputs:mdl:surface.connect = </Materials/material_20/Shader.outputs:out>
        prepend token outputs:mdl:volume.connect = </Materials/material_20/Shader.outputs:out>
